# Copy this file to .env locally if needed.
# Do not commit real API keys.

IR_SEARCH_LIVE=0

# Search providers. Leave empty if unavailable.
BOCHA_API_KEY=
EXA_API_KEY=
TAVILY_API_KEY=
ANYSEARCH_API_KEY=

# Optional local WeChat article archive.
MANUAL_WECHAT_ROOT=/ABSOLUTE/PATH/TO/manual_wechat_articles

# Optional cache directory outside this workspace.
IR_SEARCH_CACHE_DIR=/ABSOLUTE/PATH/TO/.ir_search_cache
